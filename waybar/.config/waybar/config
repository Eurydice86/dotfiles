    "modules-right": ["pulseaudio", "bluetooth", "cpu", "memory", "disk", "battery", "temperature", "sway/language", "clock", "tray", "custom/power"],
    // Modules configuration
     "sway/workspaces": {
         "disable-scroll": true,
         // "all-outputs": true,
         "warp-on-scroll": false,
         "format": "{icon}",
         "format-icons": {
             "1": "у∞≤†",
             "2": "у∞≤Ґ",
             "3": "у∞≤§",
             "4": "у∞≤¶",
             "5": "у∞≤®",
             "6": "у∞≤™",
             "7": "у∞≤ђ",
             "8": "у∞≤Ѓ",
	     "9": "у∞≤∞",
	     "10": "у∞њђ"
         }
     },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "пА£",
            "unlocked": "пВЬ"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "пЛТ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
     "custom/power": {
     "format":"вПї",
     "on-click": "waylogout --hide-cancel --screenshots --font='Iosevka Nerd Font' --fa-font='Iosevka Nerd Font' --effect-blur=7x5 --indicator-thickness=20 --ring-color=888888aa --inside-color=88888866 --text-color=eaeaeaaa --line-color=00000000 --ring-selection-color=bbff00aa --inside-selection-color=99dd00aa --text-selection-color=eaeaeaaa --line-selection-color=00000000 --logout-command='sway exit' --poweroff-command='poweroff' --reboot-command='reboot' --selection-label"
     },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) вЄ®{songPosition}|{queueLength}вЄ© {volume}% пАБ",
        "format-disconnected": "Disconnected пАБ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped пАБ",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": "пГД "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">пБі</span> ",
            "on": "пБі "
        },
        "repeat-icons": {
            "on": "пАЮ "
        },
        "single-icons": {
            "on": "пАЮ1 "
        },
        "state-icons": {
            "paused": "пБМ",
            "playing": "пБЛ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пБЃ",
            "deactivated": "пБ∞"
        }
    },
    "tray": {
